                "value": "0omacW5Xy7N1ZtcCOJoPuuyBIGwJEXHyfa7p1zDwOzM="
              }
            ],
            "skip_crds": false,
            "status": "failed",
            "timeout": 900,
            "upgrade_install": null,
            "values": [
              "executor: LocalExecutor\n\n# Disable bundled Bitnami PostgreSQL — use the existing postgresql release instead.\npostgresql:\n  enabled: false\n\nwebserver:\n  service:\n    type: NodePort\n    ports:\n      - name: airflow-ui\n        port: 8080\n        targetPort: airflow-ui\n        nodePort: 30007\n  resources:\n    requests:\n      cpu: 100m\n      memory: 256Mi\n    limits:\n      memory: 512Mi\n\nscheduler:\n  resources:\n    requests:\n      cpu: 100m\n      memory: 256Mi\n    limits:\n      memory: 512Mi\n\nmigrationJob:\n  useHelmHooks: false\n\ndata:\n  metadataConnection:\n    user: postgres\n    host: postgresql\n    port: 5432\n    db: airflow\n    sslmode: disable\n    # pass is injected via terraform set_sensitive (var.postgres_password)\n\ndags:\n  gitSync:\n    enabled: true\n    repo: https://github.com/jaymztheking/sports-data-platform.git\n    branch: main\n    subPath: dags\n    wait: 60\n\nconfig:\n  core:\n    load_examples: \"False\"\n  webserver:\n    expose_config: \"True\"\n\nenv:\n  - name: AIRFLOW_CONN_SPARK_DEFAULT\n    value: \"spark://spark-master:7077\"\n  - name: AIRFLOW_CONN_MINIO_DEFAULT\n    value: \"aws://minioadmin:minioadmin@?endpoint_url=http://minio:9000\"\n"
            ],
            "verify": false,
            "version": "1.14.0",
            "wait": true,
            "wait_for_jobs": false
          },
