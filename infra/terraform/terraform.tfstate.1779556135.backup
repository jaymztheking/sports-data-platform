            "metadata": [
              {
                "app_version": "RELEASE.2024-12-18T13-15-44Z",
                "chart": "minio",
                "first_deployed": 1779055677,
                "last_deployed": 1779549596,
                "name": "minio",
                "namespace": "data-platform",
                "notes": "\nMinIO can be accessed via port 9000 on the following DNS name from within your cluster:\nminio.data-platform.cluster.local\n\nTo access MinIO from localhost, run the below commands:\n\n  1. export POD_NAME=$(kubectl get pods --namespace data-platform -l \"release=minio\" -o jsonpath=\"{.items[0].metadata.name}\")\n\n  2. kubectl port-forward $POD_NAME 9000 --namespace data-platform\n\nRead more about port forwarding here: http://kubernetes.io/docs/user-guide/kubectl/kubectl_port-forward/\n\nYou can now access MinIO server on http://localhost:9000. Follow the below steps to connect to MinIO server with mc client:\n\n  1. Download the MinIO mc client - https://min.io/docs/minio/linux/reference/minio-mc.html#quickstart\n\n  2. export MC_HOST_minio-local=http://$(kubectl get secret --namespace data-platform minio -o jsonpath=\"{.data.rootUser}\" | base64 --decode):$(kubectl get secret --namespace data-platform minio -o jsonpath=\"{.data.rootPassword}\" | base64 --decode)@localhost:9000\n\n  3. mc ls minio-local\n\n\n",
                "revision": 2,
                "values": "{\"buckets\":[{\"name\":\"bronze\",\"policy\":\"none\"},{\"name\":\"mlflow-artifacts\",\"policy\":\"none\"},{\"name\":\"spark-warehouse\",\"policy\":\"none\"}],\"consoleService\":{\"nodePort\":30090,\"type\":\"NodePort\"},\"mode\":\"standalone\",\"persistence\":{\"enabled\":true,\"size\":\"10Gi\"},\"resources\":{\"limits\":{\"memory\":\"512Mi\"},\"requests\":{\"cpu\":\"100m\",\"memory\":\"256Mi\"}},\"rootPassword\":\"(sensitive value)\",\"rootUser\":\"minioadmin\",\"service\":{\"nodePort\":30900,\"type\":\"NodePort\"}}",
                "version": "5.4.0"
              }
            ],
            "name": "minio",
            "namespace": "data-platform",
            "pass_credentials": false,
            "postrender": [],
            "recreate_pods": false,
            "render_subchart_notes": true,
            "replace": false,
            "repository": "https://charts.min.io/",
            "repository_ca_file": null,
            "repository_cert_file": null,
            "repository_key_file": null,
            "repository_password": null,
            "repository_username": null,
            "reset_values": false,
            "reuse_values": false,
            "set": [],
            "set_list": [],
            "set_sensitive": [
              {
                "name": "rootPassword",
                "type": "",
                "value": "!qtVSpd\u0026vQlIBJXLEz2#@\u0026gR"
              }
            ],
            "skip_crds": false,
            "status": "deployed",
            "timeout": 300,
            "upgrade_install": null,
            "values": [
              "mode: standalone\n\nrootUser: minioadmin\n\nresources:\n  requests:\n    cpu: 100m\n    memory: 256Mi\n  limits:\n    memory: 512Mi\n\npersistence:\n  enabled: true\n  size: 10Gi\n\nservice:\n  type: NodePort\n  nodePort: 30900\n\nconsoleService:\n  type: NodePort\n  nodePort: 30090\n\nbuckets:\n  - name: bronze\n    policy: none\n  - name: mlflow-artifacts\n    policy: none\n  - name: spark-warehouse\n    policy: none\n"
            ],
            "verify": false,
