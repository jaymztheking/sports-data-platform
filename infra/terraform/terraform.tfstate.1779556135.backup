              "auth:\n  username: sports_data\n  database: sports_data\n\nprimary:\n  resources:\n    requests:\n      cpu: 100m\n      memory: 256Mi\n    limits:\n      memory: 512Mi\n  persistence:\n    enabled: true\n    size: 5Gi\n  service:\n    type: NodePort\n    nodePorts:\n      postgresql: \"30432\"\n\nmetrics:\n  enabled: false\n"
